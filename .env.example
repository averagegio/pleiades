# Auth
# Optional — sessions work without this; set in production for cookie hardening.
AUTH_SECRET=replace-me

# Neon Postgres (required in production / Vercel)
# Also accepts POSTGRES_URL or NEON_DATABASE_URL.
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Stripe Checkout (optional — demo checkout works without these)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# X (Twitter) API OAuth 2.0 (optional — UI shows connect status without these)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=https://your-domain.vercel.app/api/x/callback

# Optional LLM polish for the SEO agent loop
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Public site URL used in tweets + absolute metadata
NEXT_PUBLIC_SITE_URL=https://pleiades-livid-pi.vercel.app
